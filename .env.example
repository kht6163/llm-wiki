# --- llm-wiki configuration ---
# Copy to `.env` and adjust. All paths may be absolute or relative to the CWD.

# Ports (web GUI and MCP HTTP server run as two servers in one process)
GUI_PORT=8080
MCP_PORT=8081
HOST=127.0.0.1

# Where markdown documents live (the "vault"). Real .md files are stored here.
VAULT_PATH=./vault

# SQLite database file (metadata, revisions, search index, link graph, users).
DB_PATH=./data/llm_wiki.db

# Local HuggingFace sentence-transformers model (downloaded on first use, no API key).
# Alternatives: BAAI/bge-m3 (1024d, long docs), intfloat/multilingual-e5-small (384d, light).
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# Hybrid-search fusion tuning (optional). Defaults below match the built-in behavior;
# tune recall vs. latency per corpus without code changes. RRF_K is the Reciprocal-Rank-
# Fusion constant (larger = flatter rank influence). SEARCH_CANDIDATE_* set the BM25
# over-fetch (k = max(top_k * factor, min)); SEARCH_VECTOR_* set the KNN over-fetch
# (k_vec = min(k * factor, cap)) that keeps ~k distinct docs after chunk-dedup/filtering.
RRF_K=60
SEARCH_CANDIDATE_FACTOR=4
SEARCH_CANDIDATE_MIN=40
SEARCH_VECTOR_FACTOR=3
SEARCH_VECTOR_CAP=600

# Optional: secret for signing web session cookies. If empty, a persistent
# secret is generated and stored in the DB on first run.
SESSION_SECRET=

# Mark the session cookie Secure (send over HTTPS only). Leave false for local
# http; set true when serving behind TLS / a reverse proxy.
COOKIE_SECURE=false

# Logging. LOG_LEVEL: DEBUG/INFO/WARNING/ERROR/CRITICAL. LOG_FILE (optional):
# path to a size-rotated log file written in addition to stderr (empty = stderr only).
LOG_LEVEL=INFO
LOG_FILE=
